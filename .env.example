# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required for the natural-language clue-entry path.
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional — defaults to anthropic/claude-sonnet-4.6 (per SPECS §4 "Sonnet").
# Use anthropic/claude-3.5-haiku to reduce cost (~4x cheaper).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional — defaults to 8787. The deployed instance runs on 35000 (open range).
# PORT=8787
